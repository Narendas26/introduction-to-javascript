var A = 40;
var B = 30;

var sum = A + B;
console.log("Result of Summation ", sum);

var subtract = A - B;
console.log("Result of Subtraction ", subtract);

var multiply = A * B;
console.log("Result of Multiplication ", multiply);

var division = A / B;
console.log("Result of Division ", division);

var modulation = A % B;
console.log("Result of Modulation ", modulation);